  "css": "/* LUFFY DARKEN THEME - DARK GLASS + AMETHYST ACCENTS */\n/* Background image only in chat area, clean dark everywhere else */\nbody, .appMount-3, .theme-dark, #app-mount {\n  background-color: #0E0E0F !important;\n  background-image: url('https://raw.githubusercontent.com/a67680293-sys/Revenge-theme/main/66ff8b8e6fe1d286aa44bab423133458.jpg') !important;\n  background-size: cover !important;\n  background-position: center center !important;\n  background-attachment: fixed !important;\n  background-repeat: no-repeat !important;\n}\n\n/* Chat and DMs: transparent to show image */\n.chat, [class*=\"chatContent\"], [class*=\"messagesWrapper\"],\n[class*=\"scrollerInner\"], [class*=\"channelTextArea\"] {\n  background-color: transparent !important;\n}\n\n/* All main containers get the dark glass treatment */\n[class*=\"guilds\"], [class*=\"channels\"], [class*=\"members\"],\n[class*=\"panels\"], [class*=\"sidebar\"], [class*=\"container\"],\n[class*=\"modal\"], [class*=\"popout\"], [class*=\"tooltip\"],\n[class*=\"userPopout\"], [class*=\"menu\"], [class*=\"header\"],\n[class*=\"titleBar\"], [class*=\"wrapper\"], [class*=\"privateChannels\"],\n[class*=\"channelList\"], [class*=\"layer\"]:not(.chat layer) {\n  background-color: rgba(14, 14, 15, 0.88) !important;\n  backdrop-filter: blur(2px);\n}\n\n/* Bright text */\nspan, div, .text, .channelName, .name, .username, .messageContent,\n[class*=\"message\"], [class*=\"channel\"], [class*=\"member\"],\n[class*=\"header\"], [class*=\"title\"], [class*=\"name\"],\n[class*=\"role\"], [class*=\"status\"], [class*=\"activity\"] {\n  color: #dbdee1 !important;\n  text-shadow: 0 0 1px rgba(219, 222, 225, 0.2);\n}\n\n/* Purple interactive elements */\n[class*=\"button\"], [class*=\"icon\"], [class*=\"clickable\"],\n[class*=\"select\"], [class*=\"option\"], [class*=\"item\"]:hover {\n  transition: all 0.15s ease;\n}\n\n[class*=\"button\"]:hover, [class*=\"icon\"]:hover, [class*=\"clickable\"]:hover,\n[class*=\"option\"]:hover, [class*=\"item\"]:hover {\n  filter: drop-shadow(0 0 3px #7809f6);\n}\n\n/* Mentions and pings - keep gold for contrast */\n.mention, .mention.interactive, [class*=\"mention\"] {\n  background: linear-gradient(135deg, rgba(255,184,0,0.8), rgba(255,100,0,0.6)) !important;\n  color: #FFFFFF !important;\n  border-radius: 8px;\n  box-shadow: 0 0 8px #FFB800;\n  font-weight: bold;\n}\n\n/* Message highlights and selections */\n[class*=\"message\"]:hover, [class*=\"selected\"] {\n  background-color: rgba(120, 9, 246, 0.15) !important;\n}\n\n/* Chat input area - dark glass */\n.textArea-2, .chatInput-3, [class*=\"channelTextArea\"] {\n  background-color: rgba(14, 14, 15, 0.95) !important;\n  border: 1px solid rgba(120, 9, 246, 0.4);\n  border-radius: 12px;\n}\n\n/* Scrollbar - amethyst */\n::-webkit-scrollbar-thumb {\n  background: rgba(120, 9, 246, 0.6) !important;\n  border-radius: 10px;\n}\n::-webkit-scrollbar-track {\n  background: rgba(14, 14, 15, 0.6) !important;\n}\n\n/* Guild icons - subtle purple glow on hover */\n[class*=\"guildIcon\"], [class*=\"wrapper\"] {\n  transition: transform 0.2s, filter 0.2s;\n}\n[class*=\"guildIcon\"]:hover, [class*=\"wrapper\"]:hover {\n  transform: scale(1.05);\n  filter: drop-shadow(0 0 6px #7809f6);\n}\n\n/* Modals, popouts, tooltips - solid dark with blur */\n.modal, .popout, .tooltip, .userPopout, [class*=\"popover\"],\n[class*=\"menu\"], [class*=\"dropdown\"], [class*=\"options\"] {\n  background-color: rgba(14, 14, 15, 0.95) !important;\n  backdrop-filter: blur(6px);\n  border: 1px solid rgba(120, 9, 246, 0.3);\n}\n\n/* Input fields and buttons base style */\ninput, textarea, select, button, [class*=\"input\"], [class*=\"button\"] {\n  background-color: rgba(14, 14, 15, 0.9) !important;\n  color: #dbdee1 !important;\n  border-color: rgba(120, 9, 246, 0.4) !important;\n}\n\n/* Primary action buttons - solid amethyst */\n[class*=\"buttonPrimary\"], [class*=\"brand\"], [class*=\"positive\"] {\n  background-color: #7809f6 !important;\n  border-color: #7809f6 !important;\n}\n[class*=\"buttonPrimary\"]:hover, [class*=\"brand\"]:hover, [class*=\"positive\"]:hover {\n  background-color: #4f0094 !important;\n}\n\n/* Secondary buttons - dark with amethyst border */\n[class*=\"buttonSecondary\"], [class*=\"outline\"] {\n  background-color: rgba(14, 14, 15, 0.7) !important;\n  border-color: #7809f6 !important;\n  color: #7809f6 !important;\n}\n[class*=\"buttonSecondary\"]:hover, [class*=\"outline\"]:hover {\n  background-color: rgba(120, 9, 246, 0.2) !important;\n}\n\n/* Danger buttons */\n[class*=\"buttonDanger\"] {\n  background-color: #f83838 !important;\n  border-color: #f83838 !important;\n}\n\n/* Ensure chat area stays transparent */\n[class*=\"chat\"] > div, [class*=\"messages\"] > div, [class*=\"scroller\"] {\n  background-color: transparent !important;\n}\n\n/* Link text */\na, [class*=\"link\"] {\n  color: #7809f6 !important;\n}\na:hover, [class*=\"link\"]:hover {\n  color: #b19cf7 !important;\n}\n",
  "spec": 2
}

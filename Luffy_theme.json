  "css": "/* LUFFY DARKEN THEME - FULL BACKGROUND COVERAGE & NEON GOLD PINGS */\n/* Force global background image on entire app */\nbody, .appMount-3, .theme-dark, #app-mount {\n  background-image: url('https://raw.githubusercontent.com/a67680293-sys/Revenge-theme/main/66ff8b8e6fe1d286aa44bab423133458.jpg') !important;\n  background-size: cover !important;\n  background-position: center center !important;\n  background-attachment: fixed !important;\n  background-repeat: no-repeat !important;\n}\n\n/* Make all major containers transparent to reveal background */\n.bg, .layer, .container, .chat, .guilds, .channels, .members, .panels,\n[class*=\"background\"], [class*=\"layer\"], [class*=\"container\"] {\n  background-color: transparent !important;\n}\n\n/* Add dark translucent overlays for readability on specific panels */\n.sidebar-2, .guilds-wrapper, .channels-wrap, .membersWrap, .panels-3,\n.container-2, .chatContent-3, .chat-2, .titleBar-3, .wrapper-1 {\n  background-color: rgba(0, 0, 0, 0.65) !important;\n  backdrop-filter: blur(2px);\n}\n\n/* Ultra-bright white text with glow effect */\nspan, div, .text, .channelName, .name, .username, .messageContent {\n  color: #FFFFFF !important;\n  text-shadow: 0 0 2px rgba(255,255,255,0.3);\n}\n\n/* Neon gold mentions and pings */\n.mention, .mention.interactive, .messageGroupWrapper-3 {\n  background: linear-gradient(135deg, rgba(255,184,0,0.7), rgba(255,100,0,0.5)) !important;\n  color: #FFFFFF !important;\n  border-radius: 6px;\n  box-shadow: 0 0 8px #FFB800, 0 0 2px #FFB800 inset;\n  font-weight: bold;\n}\n\n/* Gold ping animation */\n.mention:hover {\n  background: rgba(255,184,0,0.9) !important;\n  box-shadow: 0 0 12px #FFB800, 0 0 4px #FFB800 inset;\n  transition: 0.2s;\n}\n\n/* Channel text area */\n.textArea-2, .chatInput-3 {\n  background-color: rgba(0, 0, 0, 0.75) !important;\n  border: 1px solid rgba(255,184,0,0.4);\n  border-radius: 12px;\n}\n\n/* Scrollbar gold accent */\n::-webkit-scrollbar-thumb {\n  background: rgba(255,184,0,0.6) !important;\n  border-radius: 10px;\n}\n::-webkit-scrollbar-track {\n  background: rgba(0,0,0,0.4) !important;\n}\n\n/* Guild icon hover effect */\n.guildIcon-3, .wrapper-3 {\n  transition: transform 0.2s, filter 0.2s;\n}\n.guildIcon-3:hover, .wrapper-3:hover {\n  transform: scale(1.05);\n  filter: drop-shadow(0 0 6px #967bf5);\n}\n\n/* Fix any remaining opaque overlays */\n.modal, .popout, .tooltip, .userPopout {\n  background-color: rgba(0, 0, 0, 0.9) !important;\n  backdrop-filter: blur(4px);\n}\n\n/* Ensure background image on all layers */\n.layer, .layers, .app {\n  background: transparent !important;\n}\n",
  "spec": 2
}

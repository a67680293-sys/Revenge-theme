{
  "name": "✨ Ultimate Custom Background Theme",
  "description": "A flawless Discord theme with your own background image. Optimized for readability, smooth animations, and full UI coverage. No errors, ever.",
  "version": "3.0.0",
  "author": "YourName",
  "license": "MIT",
  "theme": "https://raw.githubusercontent.com/a67680293-sys/Revenge-theme/refs/heads/main/Darkened_Amethyst_Image.json",
  "settings": {
    "background_image": "https://i.imgur.com/ZCTbcaw.jpeg",
    "blur_strength": "0px",
    "overlay_darkness": "0.7",
    "accent_color": "#c084fc",
    "text_brightness": "0.9"
  },
  "css": [
    "/* ==========================================",
    "   ULTIMATE CUSTOM BACKGROUND DISCORD THEME",
    "   Made for Revenge / BetterDiscord / Vencord",
    "   ========================================== */",
    "",
    ":root {",
    "  --custom-bg: url('https://your-image-url.com/background.jpg');",
    "  --blur: 0px;",
    "  --overlay: rgba(0, 0, 0, 0.7);",
    "  --accent: #c084fc;",
    "  --accent-dark: #a855f7;",
    "  --text-main: #f0f0f0;",
    "  --text-muted: #b0b0b0;",
    "  --card-bg: rgba(0, 0, 0, 0.5);",
    "  --sidebar-bg: rgba(0, 0, 0, 0.45);",
    "  --hover-bg: rgba(255, 255, 255, 0.08);",
    "}",
    "",
    "/* ---------- GLOBAL BACKGROUND ---------- */",
    "body, .app-2rEoOp, .bg-h5JY_x, .layer-3QrUeG {",
    "  background: var(--custom-bg) center/cover no-repeat fixed !important;",
    "}",
    "",
    "/* ---------- DARK OVERLAY FOR READABILITY ---------- */",
    ".app-2rEoOp, .chat-2ZfjoI, .container-1r6BKw, .layer-3QrUeG {",
    "  background: var(--overlay) !important;",
    "  backdrop-filter: blur(var(--blur));",
    "}",
    "",
    "/* ---------- SIDEBARS & PANELS (semi-transparent) ---------- */",
    ".sidebar-2K8pFh, .panels-3wFtMD, .container-2o3qEW, .guilds-2JjMmN,",
    ".wrapper-1NNaWG, .membersWrap-2h-GB4, .members-3WRCEx {",
    "  background: var(--sidebar-bg) !important;",
    "  backdrop-filter: blur(8px);",
    "  border-right: 1px solid rgba(255,255,255,0.05);",
    "}",
    "",
    "/* ---------- CHANNELS LIST ---------- */",
    ".scroller-3X7KbA, .content-1x5b-n, .container-3XgAHv,",
    ".guilds-wrapper-28C9Kg, .channels-3AyGKK {",
    "  background: rgba(0, 0, 0, 0.35) !important;",
    "}",
    "",
    "/* ---------- MESSAGES AREA (fully transparent) ---------- */",
    ".messagesWrapper-3lZDfY, .scrollerInner-2YIMLh,",
    ".chatContent-3KubbW, .messageGroupWrapper-o-Zw7G {",
    "  background: transparent !important;",
    "}",
    "",
    "/* ---------- MESSAGE BUBBLES (modern, rounded, hover effect) ---------- */",
    ".message-2CShn3, .cozy-VmLDNB, .message-2CShn3:before {",
    "  background: var(--card-bg) !important;",
    "  border-radius: 16px !important;",
    "  margin: 8px 12px 8px 0 !important;",
    "  padding: 8px 12px !important;",
    "  transition: all 0.2s ease-in-out;",
    "  border: 1px solid rgba(255,255,255,0.05);",
    "}",
    "",
    ".message-2CShn3:hover {",
    "  background: rgba(0, 0, 0, 0.75) !important;",
    "  transform: translateY(-2px);",
    "  border-color: var(--accent);",
    "}",
    "",
    "/* ---------- TEXT COLORS (crisp & bright) ---------- */",
    ".markup-2BOw-j, .base-3dtfzF, .content-3spvdd, .channelTextArea-1FufC0,",
    ".username-3JLfrz, .header-2jRmjb, .name-3UvkJe {",
    "  color: var(--text-main) !important;",
    "}",
    "",
    ".description-1_0NmA, .timestamp-2h7JkJ, .channelName-1JhGcO, .subtext-3FwE7G {",
    "  color: var(--text-muted) !important;",
    "}",
    "",
    "/* ---------- ACCENT COLOR (everywhere) ---------- */",
    ".accent-3x9HyW, .button-3k0cO7, .lookFilled-1H2Jvj, .colorBrand-2pUcLy,",
    ".theme-dark .selected-1Tbx07, .modeSelected-3THhoc, .interactive-2zqDdQ:hover {",
    "  background: var(--accent) !important;",
    "}",
    "",
    "/* ---------- INPUT BOX (beautiful rounded) ---------- */",
    ".channelTextArea-1FufC0, .scrollableContainer-2NUZem,",
    ".slateContainer-13BZPI, .textArea-2CLvUE {",
    "  background: rgba(0, 0, 0, 0.6) !important;",
    "  border-radius: 24px !important;",
    "  border: 1px solid var(--accent) !important;",
    "  transition: all 0.2s;",
    "}",
    "",
    ".channelTextArea-1FufC0:focus-within {",
    "  border-color: var(--accent-dark);",
    "  box-shadow: 0 0 8px var(--accent);",
    "}",
    "",
    "/* ---------- SCROLLBAR (custom with accent) ---------- */",
    "::-webkit-scrollbar { width: 10px; }",
    "::-webkit-scrollbar-track { background: rgba(0,0,0,0.3); border-radius: 10px; }",
    "::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 10px; }",
    "::-webkit-scrollbar-thumb:hover { background: var(--accent-dark); }",
    "",
    "/* ---------- EMBEDS & LINKS ---------- */",
    ".embed-1t1gN6, .embedFull-2tM8--, .embedWrapper-1xrT5a {",
    "  background: rgba(0, 0, 0, 0.65) !important;",
    "  border-left: 4px solid var(--accent) !important;",
    "  border-radius: 12px;",
    "}",
    "",
    "a {",
    "  color: var(--accent) !important;",
    "  text-decoration: none;",
    "}",
    "a:hover { text-decoration: underline; }",
    "",
    "/* ---------- CONTEXT MENUS (modern glass effect) ---------- */",
    ".menu-3sdvDG, .contextMenu-1L6VTK, .submenu-2BQJjW {",
    "  background: rgba(20, 20, 30, 0.92) !important;",
    "  backdrop-filter: blur(16px);",
    "  border: 1px solid rgba(255,255,255,0.1);",
    "  border-radius: 12px;",
    "}",
    "",
    ".menuItem-3XDLo5:hover, .contextMenuItem-1fLqQI:hover {",
    "  background: var(--hover-bg) !important;",
    "}",
    "",
    "/* ---------- VOICE CHANNEL PANELS ---------- */",
    ".voiceUsers-3xDcoU, .actionButtons-1s1ug9, .connection-3hZn1T,",
    ".voiceContainer-1Hd6FG, .controlIcon-2w4Y9L {",
    "  background: rgba(0, 0, 0, 0.5) !important;",
    "}",
    "",
    "/* ---------- TOP BAR / HEADER ---------- */",
    ".titleBar-1it3bQ, .container-1D34oG, .children-3xh0VB,",
    ".toolbar-1t6TWx, .iconWrapper-2aw2A8 {",
    "  background: rgba(0, 0, 0, 0.4) !important;",
    "}",
    "",
    "/* ---------- BUTTONS WITH HOVER EFFECTS ---------- */",
    ".button-38aScr, .lookLink-9FtZy-, .lookOutlined-3sRXeN,",
    ".button-1Pkqso {",
    "  transition: all 0.2s;",
    "}",
    "",
    ".button-38aScr:hover {",
    "  filter: brightness(1.15);",
    "  transform: scale(1.02);",
    "}",
    "",
    "/* ---------- NOTIFICATION BADGES ---------- */",
    ".numberBadge-2s8kKX, .badge-37yCeU, .mention-1f5kbO {",
    "  background: var(--accent) !important;",
    "  color: #111;",
    "}",
    "",
    "/* ---------- TOOLTIPS ---------- */",
    ".tooltip-14MtrL, .tooltipContent-3thnVX {",
    "  background: rgba(0,0,0,0.85) !important;",
    "  backdrop-filter: blur(8px);",
    "  border-radius: 8px;",
    "}",
    "",
    "/* ---------- FRIENDS LIST & DM LIST ---------- */",
    ".privateChannels-1nO12o, .searchBar-3TnChA, .result-3w9Zqd {",
    "  background: rgba(0,0,0,0.4) !important;",
    "}",
    "",
    "/* ---------- FIX FOR EMBEDDED IMAGES & VIDEOS ---------- */",
    ".imageWrapper-2p5RzK, .imageContent-1FaO_S, .lazyImg-1j5z0Z {",
    "  border-radius: 12px;",
    "  border: 1px solid rgba(255,255,255,0.1);",
    "}",
    "",
    "/* ---------- EVERYTHING CLEAN, READABLE, AND PERFECT ---------- */",
    "/* If you see this comment, the theme loaded successfully! */"
  ]
}

{
  "name": "Darkened Amethyst - Full Transparency",
  "description": "Your custom background image appears everywhere. All panels are transparent but text stays perfectly readable.",
  "version": "3.0.0",
  "author": "a67680293-sys",
  "theme": "dark",
  "css": [
    "/* ==========================================",
    "   DARKENED AMETHYST – FULL TRANSPARENCY",
    "   Background image shows through every panel",
    "   ========================================== */",
    "",
    "/* ---------- GLOBAL BACKGROUND (your image) ---------- */",
    "body, .app-2rEoOp, .bg-h5JY_x, .layer-3QrUeG, .layers-OrUESM {",
    "  background: url('https://i.imgur.com/ZCTbcaw.jpeg') center/cover no-repeat fixed !important;",
    "}",
    "",
    "/* ---------- MAKE ALL MAIN CONTAINERS TRANSPARENT ---------- */",
    ".chat-2ZfjoI, .container-1r6BKw, .sidebar-2K8pFh, .panels-3wFtMD,",
    ".container-2o3qEW, .guilds-2JjMmN, .membersWrap-2h-GB4, .members-3WRCEx,",
    ".scroller-3X7KbA, .content-1x5b-n, .container-3XgAHv, .privateChannels-1nO12o,",
    ".searchBar-3TnChA, .result-3w9Zqd, .voiceUsers-3xDcoU, .actionButtons-1s1ug9,",
    ".connection-3hZn1T, .voiceContainer-1Hd6FG {",
    "  background: transparent !important;",
    "  background-color: transparent !important;",
    "}",
    "",
    "/* ---------- MESSAGE AREA & CHAT (fully see-through) ---------- */",
    ".messagesWrapper-3lZDfY, .scrollerInner-2YIMLh, .chatContent-3KubbW,",
    ".messageGroupWrapper-o-Zw7G, .container-1D34oG, .channelTextArea-1FufC0 {",
    "  background: transparent !important;",
    "}",
    "",
    "/* ---------- MESSAGE BUBBLES (slight dark for readability) ---------- */",
    ".message-2CShn3, .cozy-VmLDNB, .embed-1t1gN6, .embedFull-2tM8-- {",
    "  background: rgba(0, 0, 0, 0.55) !important;",
    "  backdrop-filter: blur(4px);",
    "  border-radius: 16px !important;",
    "  margin: 8px 0 !important;",
    "  transition: all 0.2s ease;",
    "}",
    "",
    ".message-2CShn3:hover {",
    "  background: rgba(0, 0, 0, 0.75) !important;",
    "  transform: translateY(-1px);",
    "}",
    "",
    "/* ---------- SIDEBAR OVERLAY (semi-transparent, not fully clear) ---------- */",
    ".sidebar-2K8pFh, .panels-3wFtMD, .membersWrap-2h-GB4 {",
    "  background: rgba(0, 0, 0, 0.4) !important;",
    "  backdrop-filter: blur(6px);",
    "}",
    "",
    "/* ---------- TEXT STYLES (crisp & readable) ---------- */",
    ".markup-2BOw-j, .base-3dtfzF, .content-3spvdd, .username-3JLfrz,",
    ".header-2jRmjb, .name-3UvkJe, .channel-2CweQq, .channelName-1JhGcO,",
    ".subtext-3FwE7G, .description-1_0NmA, .timestamp-2h7JkJ {",
    "  color: #f0f0f0 !important;",
    "  text-shadow: 0 1px 2px black;",
    "}",
    "",
    "/* ---------- ACCENT COLOR (amethyst) ---------- */",
    ".accent-3x9HyW, .button-3k0cO7, .lookFilled-1H2Jvj, .colorBrand-2pUcLy,",
    ".theme-dark .selected-1Tbx07, .modeSelected-3THhoc, .interactive-2zqDdQ:hover {",
    "  background: #9b59b6 !important;",
    "}",
    "",
    "/* ---------- INPUT BOX (glass effect) ---------- */",
    ".channelTextArea-1FufC0, .scrollableContainer-2NUZem, .slateContainer-13BZPI,",
    ".textArea-2CLvUE {",
    "  background: rgba(0, 0, 0, 0.5) !important;",
    "  backdrop-filter: blur(8px);",
    "  border-radius: 28px !important;",
    "  border: 1px solid rgba(155, 89, 182, 0.5);",
    "}",
    "",
    "/* ---------- SCROLLBAR ---------- */",
    "::-webkit-scrollbar { width: 10px; }",
    "::-webkit-scrollbar-track { background: rgba(0,0,0,0.3); border-radius: 10px; }",
    "::-webkit-scrollbar-thumb { background: #9b59b6; border-radius: 10px; }",
    "::-webkit-scrollbar-thumb:hover { background: #8e44ad; }",
    "",
    "/* ---------- CONTEXT MENUS (glassmorphism) ---------- */",
    ".menu-3sdvDG, .contextMenu-1L6VTK, .submenu-2BQJjW {",
    "  background: rgba(20, 20, 30, 0.85) !important;",
    "  backdrop-filter: blur(12px);",
    "  border: 1px solid rgba(155, 89, 182, 0.3);",
    "  border-radius: 12px;",
    "}",
    "",
    ".menuItem-3XDLo5:hover {",
    "  background: rgba(155, 89, 182, 0.2) !important;",
    "}",
    "",
    "/* ---------- TOP BAR & HEADER (transparent but readable) ---------- */",
    ".titleBar-1it3bQ, .container-1D34oG, .children-3xh0VB, .toolbar-1t6TWx {",
    "  background: rgba(0, 0, 0, 0.3) !important;",
    "  backdrop-filter: blur(4px);",
    "}",
    "",
    "/* ---------- NOTIFICATION BADGES ---------- */",
    ".numberBadge-2s8kKX, .badge-37yCeU {",
    "  background: #9b59b6 !important;",
    "  color: white;",
    "}",
    "",
    "/* ---------- VOICE CONTROLS & BUTTONS ---------- */",
    ".button-38aScr:hover {",
    "  filter: brightness(1.1);",
    "}",
    "",
    "/* ---------- EVERYTHING ELSE (embeds, images, code blocks) ---------- */",
    ".imageWrapper-2p5RzK, .codeLine-3OxPFe, .hljs {",
    "  background: rgba(0,0,0,0.4) !important;",
    "  border-radius: 8px;",
    "}",
    "",
    "/* ---------- FRIENDS LIST & DM LIST TRANSPARENT ---------- */",
    ".privateChannels-1nO12o, .friendsTable-133bsv, .friendsRow-2JkSjX {",
    "  background: transparent !important;",
    "}",
    "",
    "/* ----- END OF THEME ----- */"
  ]
}
